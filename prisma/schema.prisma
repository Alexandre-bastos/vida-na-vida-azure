generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
  moduleFormat  = "cjs"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.NVarChar(Max)
  access_token      String? @db.NVarChar(Max)
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.NVarChar(Max)
  session_state     String?
  user              user    @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Account_userId_fkey")

  @@unique([provider, providerAccountId], map: "Account_provider_providerAccountId_key")
  @@index([userId], map: "Account_userId_fkey")
}

model cell {
  id           String           @id @default(uuid())
  name         String
  address      String?
  neighborhood String?
  dayOfWeek    Int?
  time         String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  leaderId     String?          @unique(map: "Cell_leaderId_key")
  latitude     Float?
  longitude    Float?
  kind         String           @default("REGULAR")
  leader       user?            @relation("CurrentCellLeader", fields: [leaderId], references: [id], map: "Cell_leaderId_fkey")
  memberships  cellmembership[]
  meetings     meeting[]
  visitors     visitor[]
}

model cellmembership {
  id         String    @id @default(uuid())
  startDate  DateTime  @default(now())
  endDate    DateTime?
  roleAtTime String    @default("MEMBRO")
  userId     String
  cellId     String
  cell       cell      @relation(fields: [cellId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "CellMembership_cellId_fkey")
  user       user      @relation(fields: [userId], references: [id], onUpdate: NoAction, map: "CellMembership_userId_fkey")

  @@index([cellId], map: "CellMembership_cellId_fkey")
  @@index([userId], map: "CellMembership_userId_fkey")
}

model meeting {
  id               String              @id @default(uuid())
  date             DateTime
  topic            String?
  report           String?
  photoUrl         String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  cellId           String
  cell             cell                @relation(fields: [cellId], references: [id], onDelete: Cascade, map: "Meeting_cellId_fkey")
  presences        presence[]
  visitorPresences visitorattendance[]

  @@index([cellId], map: "Meeting_cellId_fkey")
}

model notice {
  id        String   @id @default(uuid())
  title     String
  content   String
  imageUrl  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model presence {
  id           String  @id @default(uuid())
  isPresent    Boolean @default(true)
  observations String?
  meetingId    String
  userId       String
  meeting      meeting @relation(fields: [meetingId], references: [id], onUpdate: NoAction, map: "Presence_meetingId_fkey")
  user         user    @relation(fields: [userId], references: [id], onUpdate: NoAction, map: "Presence_userId_fkey")

  @@unique([meetingId, userId], map: "Presence_meetingId_userId_key")
  @@index([userId], map: "Presence_userId_fkey")
}

model session {
  id           String   @id @default(uuid())
  sessionToken String   @unique(map: "Session_sessionToken_key")
  userId       String
  expires      DateTime
  user         user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Session_userId_fkey")

  @@index([userId], map: "Session_userId_fkey")
}

model user {
  id              String              @id @default(uuid())
  name            String?
  email           String?             @unique(map: "User_email_key")
  emailVerified   DateTime?
  image           String?
  password        String?
  role            String              @default("MEMBRO")
  active          Boolean             @default(true)
  phone           String?
  birthDate       DateTime?
  gender          String?
  city            String?
  neighborhood    String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  latitude        Float?
  longitude       Float?
  accounts        account[]
  ledCell         cell?               @relation("CurrentCellLeader")
  cellHistory     cellmembership[]
  presences       presence[]
  sessions        session[]
  invitedVisitors visitor[]           @relation("VisitorInviter")
  visitorMeetings visitorattendance[] @relation("VisitorMeetingBringer")
  pushTokens      pushtoken[]
}

model verificationtoken {
  identifier String
  token      String   @unique(map: "VerificationToken_token_key")
  expires    DateTime

  @@unique([identifier, token], map: "VerificationToken_identifier_token_key")
}

model visitor {
  id           String              @id @default(uuid())
  name         String
  phone        String?
  observations String?
  createdAt    DateTime            @default(now())
  invitedById  String?
  cellId       String?
  address      String?
  email        String?
  cell         cell?               @relation(fields: [cellId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "Visitor_cellId_fkey")
  invitedBy    user?               @relation("VisitorInviter", fields: [invitedById], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "Visitor_invitedById_fkey")
  attendances  visitorattendance[]

  @@index([cellId], map: "Visitor_cellId_fkey")
  @@index([invitedById], map: "Visitor_invitedById_fkey")
}

model visitorattendance {
  id          String  @id @default(uuid())
  visitorId   String
  meetingId   String
  broughtById String?
  broughtBy   user?   @relation("VisitorMeetingBringer", fields: [broughtById], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "VisitorAttendance_broughtById_fkey")
  meeting     meeting @relation(fields: [meetingId], references: [id], onUpdate: NoAction, map: "VisitorAttendance_meetingId_fkey")
  visitor     visitor @relation(fields: [visitorId], references: [id], onUpdate: NoAction, map: "VisitorAttendance_visitorId_fkey")

  @@unique([visitorId, meetingId], map: "VisitorAttendance_visitorId_meetingId_key")
  @@index([meetingId], map: "VisitorAttendance_meetingId_fkey")
  @@index([visitorId], map: "VisitorAttendance_visitorId_fkey")
  @@index([broughtById], map: "VisitorAttendance_broughtById_fkey")
}

model lesson {
  id        String   @id @default(uuid())
  title     String
  fileUrl   String
  fileName  String?
  active    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isNext    Boolean  @default(false)
}

model pushtoken {
  id        String   @id @default(uuid())
  token     String   @unique(map: "PushToken_token_key")
  userId    String
  createdAt DateTime @default(now())
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
