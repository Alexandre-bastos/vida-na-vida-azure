---
import AppLayout from '../../layouts/AppLayout.astro';
import { getSession } from 'auth-astro/server';
import prisma from '../../lib/prisma';
import { ChevronLeft, Calendar, Megaphone } from 'lucide-react';

const session = await getSession(Astro.request);
if (!session) return Astro.redirect('/login');

const { id } = Astro.params;
const notice = await prisma.notice.findUnique({ where: { id } });

if (!notice || !notice.active) {
  return Astro.redirect('/');
}
---

<AppLayout title={notice.title}>
  <div class="max-w-2xl mx-auto space-y-6">
    <header class="flex items-center gap-4">
      <a href="/" class="w-10 h-10 rounded-xl bg-white shadow-sm border border-gray-100 flex items-center justify-center text-gray-500 hover:text-brand-primary transition-colors">
        <ChevronLeft size={20} />
      </a>
      <div>
        <h1 class="text-xl font-bold text-brand-dark">Aviso da Liderança</h1>
        <div class="flex items-center gap-2 text-xs text-gray-400 font-bold uppercase tracking-widest mt-0.5">
          <Calendar size={12} />
          {new Date(notice.createdAt).toLocaleDateString('pt-BR')}
        </div>
      </div>
    </header>

    <article class="bg-white rounded-[2.5rem] shadow-sm border border-gray-100 overflow-hidden">
      {notice.imageUrl && (
        <div class="w-full border-b border-gray-100 bg-gray-50 flex items-center justify-center">
          <img src={notice.imageUrl} alt={notice.title} class="w-full h-auto max-h-[600px] object-contain" />
        </div>
      )}
      
      <div class="p-8 space-y-4">
        <div class="flex items-center gap-3 text-brand-primary">
          <div class="w-10 h-10 rounded-full bg-brand-bg flex items-center justify-center">
            <Megaphone size={20} />
          </div>
          <h2 class="text-2xl font-black tracking-tight">{notice.title}</h2>
        </div>
        
        <div class="text-gray-600 leading-relaxed whitespace-pre-line text-lg">
          {notice.content}
        </div>
      </div>
    </article>

    <div class="text-center pt-4">
      <a href="/" class="text-sm font-bold text-gray-400 hover:text-brand-primary transition-colors">Voltar para o Início</a>
    </div>
  </div>
</AppLayout>
