---
import AppLayout from '../../layouts/AppLayout.astro';
import { getSession } from 'auth-astro/server';
import prisma from '../../lib/prisma';
import { ChevronLeft, BookOpen, UploadCloud } from 'lucide-react';

const session = await getSession(Astro.request);
if (!session) return Astro.redirect('/login');

const userRole = (session.user as any)?.role;
if (userRole !== 'ADMIN' && userRole !== 'COORDENADOR') {
  return Astro.redirect('/');
}

let error = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const title = formData.get('title')?.toString();
  const active = formData.get('active') === 'on';

  // Upload arquivo via Vercel Blob
  const file = formData.get('file') as unknown as File;
  let fileUrl = null;
  let fileName = null;
  
  if (file && (file as any).size > 0) {
    try {
      const { put } = await import('@vercel/blob');
      const buffer = await (file as any).arrayBuffer();
      // Não usamos compressão de imagem pois pode ser PDF, DOCX etc.
      const blob = await put(`licoes/${Date.now()}-${(file as any).name}`, buffer, {
        access: 'public',
      });
      fileUrl = blob.url;
      fileName = (file as any).name;
    } catch (err) {
      console.error("Erro ao fazer upload da lição:", err);
      error = "Erro ao fazer upload do arquivo. Tente novamente.";
    }
  } else {
    error = "O arquivo do material é obrigatório.";
  }

  if (title && fileUrl && !error) {
    // Se for marcada como ativa, desativar as outras
    if (active) {
      await prisma.lesson.updateMany({ data: { active: false } });
    }
    
    await prisma.lesson.create({
      data: { title, fileUrl, fileName, active }
    });
    return Astro.redirect('/licoes');
  }
}
---

<AppLayout title="Nova Lição">
  <div class="space-y-6 max-w-2xl mx-auto">
    <header class="flex items-center gap-4 mb-8">
      <a href="/licoes" class="w-10 h-10 rounded-xl bg-white shadow-sm border border-gray-100 flex items-center justify-center text-gray-500 hover:text-brand-primary transition-colors">
        <ChevronLeft size={20} />
      </a>
      <div>
        <h2 class="text-xl font-bold text-brand-dark">Enviar Nova Lição</h2>
        <p class="text-xs text-gray-500">Faça o upload do material para os membros.</p>
      </div>
    </header>

    {error && (
      <div class="bg-red-50 border border-red-200 text-red-800 p-4 rounded-2xl">
        <span class="text-sm font-bold">{error}</span>
      </div>
    )}

    <form method="POST" enctype="multipart/form-data" class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-gray-100 space-y-6">
      <div class="space-y-1.5">
        <label class="text-[11px] font-bold text-gray-400 uppercase tracking-widest ml-1">Título da Lição</label>
        <input 
          type="text" 
          name="title" 
          required 
          placeholder="Ex: Lição da Semana - 25/08"
          class="w-full px-5 py-4 rounded-2xl border border-gray-100 bg-gray-50/50 focus:bg-white focus:outline-none focus:ring-4 focus:ring-brand-primary/5 transition-all"
        />
      </div>

      <div class="space-y-1.5">
        <label class="text-[11px] font-bold text-gray-400 uppercase tracking-widest ml-1">Arquivo (PDF, DOCX, Imagem, etc)</label>
        <label class="block w-full cursor-pointer">
          <div id="drop-zone" class="w-full px-5 py-10 border-2 border-dashed border-brand-primary/30 rounded-2xl bg-brand-light/10 hover:bg-brand-light/30 transition-all flex flex-col items-center justify-center gap-3 text-sm text-gray-500 font-medium relative overflow-hidden">
            <div id="file-loading" class="absolute inset-0 bg-white/80 backdrop-blur-sm flex flex-col items-center justify-center hidden z-10">
              <div class="w-8 h-8 border-4 border-brand-primary border-t-transparent rounded-full animate-spin"></div>
              <span class="text-[10px] text-brand-primary font-bold mt-2 uppercase tracking-widest">Preparando Arquivo...</span>
            </div>
            
            <div class="w-14 h-14 bg-white rounded-2xl shadow-sm flex items-center justify-center text-brand-primary border border-brand-light">
              <UploadCloud size={28} />
            </div>
            <div class="text-center">
              <span id="file-name" class="block font-bold text-brand-dark mb-1">Clique para selecionar o arquivo</span>
              <span class="text-xs text-gray-400">Até 4.5MB permitido pelo Vercel</span>
            </div>
          </div>
          <input type="file" name="file" required class="hidden" id="file-input" />
        </label>
      </div>

      <script>
        const fileInput = document.getElementById('file-input') as HTMLInputElement;
        const fileNameDisplay = document.getElementById('file-name');
        
        fileInput?.addEventListener('change', (e: any) => {
          const target = e.target as HTMLInputElement;
          if (!target.files || target.files.length === 0) return;
          const file = target.files[0];
          if (fileNameDisplay) {
            fileNameDisplay.innerText = file.name;
            fileNameDisplay.classList.add('text-brand-primary');
          }
        });

        // Submit loading state
        const form = document.querySelector('form');
        const submitBtn = document.getElementById('submit-btn');
        const submitText = document.getElementById('submit-text');
        const submitIcon = document.getElementById('submit-icon');

        if (form) {
          form.addEventListener('submit', () => {
            if (submitBtn && submitText) {
              submitBtn.style.pointerEvents = 'none';
              submitBtn.style.opacity = '0.7';
              submitText.innerText = 'Enviando...';
              if (submitIcon) {
                submitIcon.innerHTML = '<div class="w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin"></div>';
              }
            }
          });
        }
      </script>

      <div class="flex items-center gap-3 p-4 bg-gray-50 rounded-2xl border border-gray-100">
        <label class="relative inline-flex items-center cursor-pointer">
          <input type="checkbox" name="active" checked class="sr-only peer">
          <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-brand-primary/20 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-brand-primary"></div>
        </label>
        <div>
          <span class="block text-sm font-bold text-gray-700">Disponibilizar para download</span>
          <span class="block text-[10px] text-gray-500">Isso irá substituir a lição ativa anterior.</span>
        </div>
      </div>

      <div class="flex gap-4 pt-4">
        <a href="/licoes" class="flex-1 px-6 py-4 rounded-2xl border border-gray-100 font-bold text-gray-400 text-center hover:bg-gray-50 transition-all">Cancelar</a>
        <button id="submit-btn" type="submit" class="flex-1 px-6 py-4 rounded-2xl bg-brand-primary text-white font-bold hover:brightness-110 shadow-lg shadow-brand-primary/20 transition-all flex items-center justify-center gap-2">
          <span id="submit-icon"><BookOpen size={18} /></span>
          <span id="submit-text">Salvar Lição</span>
        </button>
      </div>
    </form>
  </div>
</AppLayout>
