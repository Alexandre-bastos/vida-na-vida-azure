---
import AppLayout from '../layouts/AppLayout.astro';
import { getSession } from 'auth-astro/server';
import prisma from '../lib/prisma';
import { Camera, Save, MapPin, User as UserIcon, CheckCircle, Shield, Phone } from 'lucide-react';
import bcrypt from 'bcryptjs';

const session = await getSession(Astro.request);
if (!session) return Astro.redirect('/login');

const userId = (session.user as any)?.id;
const user = await prisma.user.findUnique({
  where: { id: userId },
  include: {
    cellHistory: {
      where: { endDate: null },
      include: { cell: true }
    },
    _count: {
      select: { presences: { where: { isPresent: true } } }
    }
  }
});

if (!user) return Astro.redirect('/login');

let success = false;
let error = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const name = formData.get('name')?.toString();
  const email = formData.get('email')?.toString();
  const phone = formData.get('phone')?.toString();
  const gender = formData.get('gender')?.toString();
  const city = formData.get('city')?.toString();
  const neighborhood = formData.get('neighborhood')?.toString();
  
  // Upload Foto
  const imageFile = formData.get('image') as unknown as File;
  let image = user.image;

  if (imageFile && (imageFile as any).size > 0) {
    try {
      const { put } = await import('@vercel/blob');
      const buffer = await (imageFile as any).arrayBuffer();
      const blob = await put(`profiles/${userId}-${Date.now()}-${(imageFile as any).name}`, buffer, {
        access: 'public',
      });
      image = blob.url;
    } catch (err) {
      console.error("Erro ao fazer upload para o Vercel Blob:", err);
      error = "Erro ao fazer upload da imagem. O Vercel Blob não está configurado corretamente.";
    }
  }

  const newPassword = formData.get('newPassword')?.toString();
  const confirmPassword = formData.get('confirmPassword')?.toString();
  
  if (!error) {
    let updateData: any = {
      name: name || user.name,
      phone: phone || user.phone,
      gender: gender || user.gender,
      city: city || user.city,
      neighborhood: neighborhood || user.neighborhood,
      image
    };

    // Só permite alterar email se for o default
    if (user.email === 'vidanavida' && email && email !== 'vidanavida') {
        updateData.email = email;
    }

    if (newPassword && newPassword === confirmPassword && newPassword.length >= 6) {
      updateData.password = bcrypt.hashSync(newPassword, 10);
    }

    try {
      await prisma.user.update({
        where: { id: userId },
        data: updateData
      });
      success = true;
      return Astro.redirect('/?profile_updated=1');
    } catch (dbError) {
      console.error("Erro ao salvar no banco:", dbError);
      error = "Erro ao salvar as informações no banco de dados.";
    }
  }
}

const isSuccess = Astro.url.searchParams.get('success') === '1';
const forceChange = Astro.url.searchParams.get('forceChange') === '1';
const isDefaultLogin = user.email === 'vidanavida';
---

<AppLayout title="Meu Perfil">
  <div class="max-w-2xl mx-auto space-y-6">
    <header>
      <h1 class="text-2xl font-bold text-brand-dark">Meu Perfil</h1>
      <p class="text-sm text-gray-500 mt-1">Gerencie suas informações e personalização.</p>
    </header>

    {isSuccess && (
      <div class="bg-green-50 border border-green-100 text-green-800 p-4 rounded-2xl flex items-center gap-3 animate-in fade-in slide-in-from-top-2">
        <CheckCircle size={20} />
        <span class="text-sm font-bold">Perfil atualizado com sucesso!</span>
      </div>
    )}

    {forceChange && (
      <div class="bg-amber-50 border border-amber-200 text-amber-800 p-4 rounded-2xl flex flex-col gap-2 animate-bounce-subtle">
        <div class="flex items-center gap-3">
          <Shield size={20} class="text-brand-accent" />
          <span class="text-sm font-bold uppercase tracking-wider">Ação Necessária: Segurança</span>
        </div>
        <p class="text-xs opacity-80">Você está utilizando as credenciais padrão do sistema. Para sua segurança, é obrigatório alterar sua senha (e e-mail se necessário) antes de continuar.</p>
      </div>
    )}

    {error && (
      <div class="bg-red-50 border border-red-100 text-red-800 p-4 rounded-2xl flex items-center gap-3 animate-in fade-in slide-in-from-top-2">
        <span class="text-sm font-bold">{error}</span>
      </div>
    )}

    <form id="profile-form" method="POST" enctype="multipart/form-data" class="space-y-6">
      <!-- Card Principal: Foto e Identidade -->
      <section class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-gray-100 text-center space-y-6">
        <div class="relative w-32 h-32 mx-auto">
          <div class="w-full h-full rounded-full overflow-hidden border-4 border-brand-bg shadow-inner bg-gray-50 flex items-center justify-center relative">
            <img id="preview" src={user.image || ''} alt={user.name || ''} class={`w-full h-full object-cover transition-opacity ${user.image ? '' : 'hidden'}`} />
            {!user.image && <UserIcon id="fallback-icon" size={48} class="text-gray-300 absolute" />}
            
            <!-- Overlay de loading para imagem -->
            <div id="image-loading" class="absolute inset-0 bg-black/50 flex flex-col items-center justify-center hidden">
              <div class="w-6 h-6 border-2 border-white border-t-transparent rounded-full animate-spin"></div>
              <span class="text-[9px] text-white font-bold mt-1 uppercase">Processando</span>
            </div>
          </div>
          <label class="absolute bottom-0 right-0 w-10 h-10 bg-brand-primary text-white rounded-full flex items-center justify-center shadow-lg cursor-pointer hover:scale-110 transition-transform">
            <Camera size={18} />
            <input type="file" name="image" accept="image/*" class="hidden" id="image-input" />
          </label>
        </div>

        <div>
          <h2 class="text-xl font-black text-brand-dark">{user.name}</h2>
          <p class="text-xs font-bold text-brand-primary uppercase tracking-widest mt-1">{user.role}</p>
        </div>

        <div class="grid grid-cols-2 gap-4 pt-4 border-t border-gray-50">
          <div class="text-center">
            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Célula Atual</p>
            <p class="text-sm font-bold text-gray-700 mt-1">{user.cellHistory[0]?.cell.name || 'Sem célula'}</p>
          </div>
          <div class="text-center">
            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Presenças</p>
            <p class="text-sm font-bold text-gray-700 mt-1">{user._count.presences} encontros</p>
          </div>
        </div>
      </section>

      <!-- Dados Pessoais -->
      <section class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-gray-100 space-y-6">
        <h3 class="font-bold text-brand-dark flex items-center gap-2">
          <UserIcon size={18} class="text-brand-primary" />
          Informações Pessoais
        </h3>

        <div class="grid gap-4">
          <div class="space-y-1.5">
            <label class="text-[11px] font-bold text-gray-400 uppercase tracking-widest ml-1">Nome Completo</label>
            <input type="text" name="name" value={user.name} class="w-full px-5 py-4 rounded-2xl border border-gray-100 bg-gray-50/50 focus:bg-white focus:outline-none focus:ring-4 focus:ring-brand-primary/5 transition-all" />
          </div>

          <div class="space-y-1.5">
            <label class="text-[11px] font-bold text-gray-400 uppercase tracking-widest ml-1">E-mail (Login)</label>
            <input 
                type="email" 
                name="email" 
                value={user.email} 
                readonly={!isDefaultLogin}
                class={`w-full px-5 py-4 rounded-2xl border border-gray-100 focus:outline-none transition-all ${isDefaultLogin ? 'bg-amber-50 focus:bg-white focus:ring-4 focus:ring-brand-primary/5 border-amber-200' : 'bg-gray-100 text-gray-400 cursor-not-allowed'}`} 
            />
            {!isDefaultLogin && <p class="text-[9px] text-gray-400 ml-1">O e-mail é sua chave de acesso e não pode ser alterado.</p>}
          </div>

          <div class="space-y-1.5">
            <label class="text-[11px] font-bold text-gray-400 uppercase tracking-widest ml-1">Telefone</label>
            <div class="relative">
              <Phone size={16} class="absolute left-5 top-1/2 -translate-y-1/2 text-gray-400" />
              <input 
                type="tel" 
                name="phone" 
                value={user.phone || ''} 
                placeholder="(11) 99999-9999" 
                class="w-full pl-12 pr-5 py-4 rounded-2xl border border-gray-100 bg-gray-50/50 focus:bg-white focus:outline-none focus:ring-4 focus:ring-brand-primary/5 transition-all phone-mask" 
              />
            </div>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div class="space-y-1.5">
              <label class="text-[11px] font-bold text-gray-400 uppercase tracking-widest ml-1">Sexo</label>
              <select name="gender" class="w-full px-5 py-4 rounded-2xl border border-gray-100 bg-gray-50/50 focus:bg-white outline-none appearance-none">
                <option value="">Selecione</option>
                <option value="M" selected={user.gender === 'M'}>Masculino</option>
                <option value="F" selected={user.gender === 'F'}>Feminino</option>
              </select>
            </div>
            <div class="space-y-1.5">
              <label class="text-[11px] font-bold text-gray-400 uppercase tracking-widest ml-1">Município</label>
              <input type="text" name="city" value={user.city || ''} placeholder="Ex: Rio de Janeiro" class="w-full px-5 py-4 rounded-2xl border border-gray-100 bg-gray-50/50 focus:bg-white focus:outline-none focus:ring-4 focus:ring-brand-primary/5 transition-all" />
            </div>
          </div>

          <div class="space-y-1.5">
            <label class="text-[11px] font-bold text-gray-400 uppercase tracking-widest ml-1">Bairro</label>
            <div class="relative">
              <MapPin size={16} class="absolute left-5 top-1/2 -translate-y-1/2 text-gray-400" />
              <input type="text" name="neighborhood" value={user.neighborhood || ''} placeholder="Ex: Copacabana" class="w-full pl-12 pr-5 py-4 rounded-2xl border border-gray-100 bg-gray-50/50 focus:bg-white focus:outline-none focus:ring-4 focus:ring-brand-primary/5 transition-all" />
            </div>
          </div>
        </div>
      </section>

      <!-- Alterar Senha -->
      <section class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-gray-100 space-y-6">
        <h3 class="font-bold text-brand-dark flex items-center gap-2">
          <Shield size={18} class="text-brand-accent" />
          Segurança e Senha
        </h3>
        
        <p class="text-[11px] text-gray-400">Preencha apenas se desejar alterar sua senha atual.</p>

        <div class="grid sm:grid-cols-2 gap-4">
          <div class="space-y-1.5">
            <label class="text-[11px] font-bold text-gray-400 uppercase tracking-widest ml-1">Nova Senha</label>
            <input type="password" name="newPassword" placeholder="Mínimo 6 caracteres" class="w-full px-5 py-4 rounded-2xl border border-gray-100 bg-gray-50/50 focus:bg-white focus:outline-none focus:ring-4 focus:ring-brand-primary/5 transition-all" />
          </div>
          <div class="space-y-1.5">
            <label class="text-[11px] font-bold text-gray-400 uppercase tracking-widest ml-1">Confirmar Senha</label>
            <input type="password" name="confirmPassword" placeholder="Repita a nova senha" class="w-full px-5 py-4 rounded-2xl border border-gray-100 bg-gray-50/50 focus:bg-white focus:outline-none focus:ring-4 focus:ring-brand-primary/5 transition-all" />
          </div>
        </div>
      </section>

      <div class="flex gap-4">
        <a href="/" class="flex-1 px-6 py-4 rounded-2xl border border-gray-100 font-bold text-gray-400 text-center hover:bg-gray-50 transition-all">Voltar</a>
        <button id="submit-btn" type="submit" class="flex-1 px-6 py-4 rounded-2xl bg-brand-primary text-white font-bold hover:brightness-110 shadow-lg shadow-brand-primary/20 transition-all flex items-center justify-center gap-2">
          <span id="save-icon-container"><Save size={18} /></span>
          <span id="submit-text">Salvar Alterações</span>
        </button>
      </div>
    </form>
  </div>
</AppLayout>

<script>
  // Máscara de telefone (Brasileiro)
  const phoneInputs = document.querySelectorAll('.phone-mask');
  
  phoneInputs.forEach(input => {
    input.addEventListener('input', (e: any) => {
      let value = e.target.value.replace(/\D/g, '');
      if (value.length > 11) value = value.slice(0, 11);
      
      if (value.length > 10) {
        // (99) 99999-9999
        value = value.replace(/^(\d{2})(\d{5})(\d{4}).*/, '($1) $2-$3');
      } else if (value.length > 5) {
        // (99) 9999-9999
        value = value.replace(/^(\d{2})(\d{4})(\d{0,4}).*/, '($1) $2-$3');
      } else if (value.length > 2) {
        // (99) 9999
        value = value.replace(/^(\d{2})(\d{0,5})/, '($1) $2');
      } else if (value.length > 0) {
        // (99
        value = value.replace(/^(\d{0,2})/, '($1');
      }
      
      e.target.value = value;
    });
  });

  // Compressão de Imagem
  import { compressImage } from '../lib/image-compression';

  const imageInput = document.getElementById('image-input') as HTMLInputElement;
  const previewImg = document.getElementById('preview') as HTMLImageElement;
  const fallbackIcon = document.getElementById('fallback-icon');
  const imageLoading = document.getElementById('image-loading');

  imageInput?.addEventListener('change', async (e: any) => {
    const target = e.target as HTMLInputElement;
    if (!target.files || target.files.length === 0) return;

    const file = target.files[0];
    
    // Mostra loading
    if (imageLoading) imageLoading.classList.remove('hidden');
    
    // Preview imediato
    const reader = new FileReader();
    reader.onload = (re: any) => {
      if (previewImg) {
        previewImg.src = re.target.result;
        previewImg.classList.remove('hidden');
        if (fallbackIcon) fallbackIcon.style.display = 'none';
      }
    };
    reader.readAsDataURL(file);

    // Comprimir se for imagem grande
    if (file.type.startsWith('image/')) {
        try {
            const compressedFile = await compressImage(file);
            
            // Substitui o arquivo no input usando DataTransfer
            const dataTransfer = new DataTransfer();
            dataTransfer.items.add(compressedFile);
            target.files = dataTransfer.files;
            
            console.log(`Imagem comprimida: de ${(file.size / 1024).toFixed(1)}KB para ${(compressedFile.size / 1024).toFixed(1)}KB`);
        } catch (err) {
            console.error('Erro ao comprimir imagem:', err);
        } finally {
            // Esconde loading
            if (imageLoading) imageLoading.classList.add('hidden');
        }
    } else {
        if (imageLoading) imageLoading.classList.add('hidden');
    }
  });

  // Estado de loading no formulário principal
  const profileForm = document.getElementById('profile-form');
  const submitBtn = document.getElementById('submit-btn');
  const submitText = document.getElementById('submit-text');
  const saveIconContainer = document.getElementById('save-icon-container');

  if (profileForm) {
    profileForm.addEventListener('submit', () => {
      if (submitBtn && submitText) {
        submitBtn.style.pointerEvents = 'none';
        submitBtn.style.opacity = '0.7';
        submitText.innerText = 'Processando...';
        if (saveIconContainer) {
          saveIconContainer.innerHTML = '<div class="w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin"></div>';
        }
      }
    });
  }
</script>

