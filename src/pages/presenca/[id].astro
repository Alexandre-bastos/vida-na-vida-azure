---
import AppLayout from '../../layouts/AppLayout.astro';
import { ChevronLeft, Edit, Calendar, MapPin, Users } from 'lucide-react';
import { getSession } from 'auth-astro/server';
import prisma from '../../lib/prisma';

let session = await getSession(Astro.request);
if (!session?.user) {
  return Astro.redirect('/login');
}

const { id } = Astro.params;

const meeting = await prisma.meeting.findUnique({
  where: { id },
  include: {
    cell: true,
    presences: {
      include: { user: true },
      orderBy: { user: { name: 'asc' } }
    }
  }
});

if (!meeting) {
  return Astro.redirect('/presenca');
}

const presentCount = meeting.presences.filter(p => p.isPresent).length;
const totalCount = meeting.presences.length;
---

<AppLayout title="Visualizar Presença">
  <div class="space-y-6 max-w-3xl mx-auto">
    <header class="flex items-center justify-between">
      <div class="flex items-center gap-4">
        <a href="/presenca" class="w-10 h-10 rounded-lg bg-white shadow flex items-center justify-center hover:bg-gray-50 transition-colors">
          <ChevronLeft size={18} />
        </a>
        <div>
          <h1 class="text-xl font-bold">Detalhes do Encontro</h1>
          <p class="text-sm text-gray-500">Visualização de presença (modo leitura).</p>
        </div>
      </div>
      <a href={`/presenca/nova?meetingId=${meeting.id}`} class="flex items-center gap-2 bg-white border border-gray-200 text-gray-700 px-4 py-2 rounded-2xl shadow-sm hover:bg-gray-50 transition-all font-medium text-sm">
        <Edit size={16} />
        <span class="hidden sm:inline">Editar Registro</span>
      </a>
    </header>

    <div class="bg-white p-6 rounded-3xl shadow-sm border border-gray-100 flex flex-col md:flex-row justify-between gap-6">
      <div class="space-y-4 flex-1">
        <div>
          <h2 class="text-2xl font-bold text-gray-800">{meeting.topic || 'Encontro da Célula'}</h2>
          <div class="flex items-center gap-2 mt-2 text-sm font-medium text-brand-primary">
            <MapPin size={16} />
            {meeting.cell?.name}
          </div>
          <div class="flex items-center gap-2 mt-1 text-sm text-gray-500">
            <Calendar size={16} />
            {new Date(meeting.date).toLocaleDateString()} às {new Date(meeting.date).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}
          </div>
        </div>

        {meeting.report && (
          <div class="mt-4 pt-4 border-t border-gray-100">
            <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Relatório / Observações Gerais</h3>
            <p class="text-sm text-gray-700 whitespace-pre-line leading-relaxed bg-gray-50 p-4 rounded-xl">
              {meeting.report}
            </p>
          </div>
        )}
      </div>

      {meeting.photoUrl && (
        <div class="md:w-1/2 flex-shrink-0 flex items-center justify-center bg-gray-50 rounded-[2rem] overflow-hidden border border-gray-100 shadow-md">
          <img src={meeting.photoUrl} alt="Foto do encontro" class="w-full h-auto max-h-[500px] object-contain" />
        </div>
      )}
    </div>

    <section class="bg-white p-6 rounded-3xl shadow-sm border border-gray-100">
      <div class="flex items-center justify-between mb-6">
        <div>
          <h3 class="font-bold text-gray-800 text-lg flex items-center gap-2">
            <Users size={20} class="text-brand-primary" />
            Lista de Presença
          </h3>
        </div>
        <div class="bg-brand-light/30 text-brand-dark px-4 py-1.5 rounded-full text-sm font-bold">
          {presentCount} / {totalCount} presentes
        </div>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {meeting.presences.map(p => (
          <div class={`flex flex-col p-4 rounded-2xl border transition-colors ${p.isPresent ? 'border-green-100 bg-green-50/30' : 'border-red-100 bg-red-50/30'}`}>
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-3">
                <div class={`w-10 h-10 rounded-full flex items-center justify-center font-bold text-sm overflow-hidden border ${p.isPresent ? 'bg-green-100 text-green-700 border-green-200' : 'bg-red-100 text-red-700 border-red-200'}`}>
                  {p.user.image ? (
                    <img src={p.user.image} alt={p.user.name || ''} class="w-full h-full object-cover" />
                  ) : (
                    <span>{p.user.name?.charAt(0)}</span>
                  )}
                </div>
                <div>
                  <div class={`font-bold ${p.isPresent ? 'text-gray-800' : 'text-gray-500'}`}>{p.user.name}</div>
                  <div class="text-xs text-gray-400 font-medium">{p.user.role}</div>
                </div>
              </div>
              <div>
                {p.isPresent ? (
                  <span class="bg-green-100 text-green-700 text-xs font-bold px-2 py-1 rounded-md">Presente</span>
                ) : (
                  <span class="bg-red-100 text-red-700 text-xs font-bold px-2 py-1 rounded-md">Faltou</span>
                )}
              </div>
            </div>
            
            {p.observations && (
              <div class="mt-3 pt-3 border-t border-gray-100/50">
                <div class="text-xs text-gray-500 bg-white/60 p-2 rounded-lg italic">
                  "{p.observations}"
                </div>
              </div>
            )}
          </div>
        ))}
      </div>
    </section>
  </div>
</AppLayout>
