---
import AppLayout from '../../layouts/AppLayout.astro';
import { ChevronLeft, Camera } from 'lucide-react';
import { getSession } from 'auth-astro/server';
import prisma from '../../lib/prisma';

let session = await getSession(Astro.request);
if (!session?.user) {
  return Astro.redirect('/login');
}

const userId = (session.user as any)?.id;
const userRole = (session.user as any)?.role || 'MEMBRO';
const isAdmin = userRole === 'ADMIN';
const isCoordinator = userRole === 'COORDENADOR';
const isLeader = userRole === 'LIDER' || userRole === 'LIDER_TREINAMENTO';

// GET params
const url = new URL(Astro.request.url);
const qCellId = url.searchParams.get('cellId') || null;
const qDate = url.searchParams.get('date') || null;
const qMeetingId = url.searchParams.get('meetingId') || url.searchParams.get('existing') || null;

// Load cells depending on role
let availableCells = [];
if (isAdmin || isCoordinator) {
  availableCells = await prisma.cell.findMany({ orderBy: { name: 'asc' } });
} else if (isLeader) {
  availableCells = await prisma.cell.findMany({ where: { leaderId: userId }, orderBy: { name: 'asc' } });
}

// Default selected cell
let selectedCellId = qCellId;
if (!selectedCellId && isLeader && availableCells.length > 0) selectedCellId = availableCells[0].id;

// Parse date
let selectedDate = qDate ? new Date(qDate) : new Date();

// If meetingId is provided, load the meeting
let meeting = null;
let meetingPresencesMap = new Map();
if (qMeetingId) {
  meeting = await prisma.meeting.findUnique({ where: { id: qMeetingId }, include: { presences: { include: { user: true } }, visitors: true, cell: true } });
  if (meeting) {
    selectedCellId = meeting.cellId;
    selectedDate = meeting.date;
    meeting.presences && meeting.presences.forEach(p => meetingPresencesMap.set(p.userId, p));
  }
}

// Get members
async function loadMembers(cellId) {
  if (!cellId) return [];
  return await prisma.cellmembership.findMany({
    where: { cellId, endDate: null },
    include: { user: true },
    orderBy: { user: { name: 'asc' } }
  });
}
const members = selectedCellId ? await loadMembers(selectedCellId) : [];

// POST handling
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const cellId = formData.get('cellId')?.toString();
  const dateStr = formData.get('date')?.toString();
  const topic = formData.get('topic')?.toString() || null;
  const report = formData.get('report')?.toString() || null;
  let existingMeetingId = formData.get('meetingId')?.toString() || null;

  // Permission check
  if (!(isAdmin || isCoordinator || (isLeader && (await prisma.cell.findFirst({ where: { id: cellId, leaderId: userId } }))))) {
    return Astro.redirect('/presenca');
  }

  const meetingDate = dateStr ? new Date(dateStr) : new Date();
  const startOfDay = new Date(meetingDate); startOfDay.setHours(0,0,0,0);
  const endOfDay = new Date(meetingDate); endOfDay.setHours(23,59,59,999);

  // Upload photo
  const photo = formData.get('photo') as unknown as File;
  let photoUrl = null;
  if (photo && (photo as any).size > 0) {
    try {
      const { put } = await import('@vercel/blob');
      const buffer = await (photo as any).arrayBuffer();
      const blob = await put(`meetings/${Date.now()}-${(photo as any).name}`, buffer, {
        access: 'public',
      });
      photoUrl = blob.url;
    } catch (err) {
      console.error("Erro ao fazer upload da foto do encontro:", err);
      // Aqui poderíamos definir um erro, mas para não impedir o envio da presença, apenas logamos.
    }
  }

  let finalMeetingId = existingMeetingId;

  if (existingMeetingId) {
    await prisma.meeting.update({ where: { id: existingMeetingId }, data: { date: meetingDate, topic, report, photoUrl: photoUrl || undefined, cellId } });
    await prisma.presence.deleteMany({ where: { meetingId: existingMeetingId } });
  } else {
    // Check if one already exists for this day/cell
    const existing = await prisma.meeting.findFirst({ where: { cellId, date: { gte: startOfDay, lt: endOfDay } } });
    if (existing) {
      return Astro.redirect(`/presenca/nova?cellId=${cellId}&date=${meetingDate.toISOString().slice(0,10)}&existing=${existing.id}`);
    }
    const newMeeting = await prisma.meeting.create({ data: { date: meetingDate, topic, report, photoUrl, cellId } });
    finalMeetingId = newMeeting.id;
  }

  // Create presences
  const presencePromises = [];
  const entries = Array.from(formData.entries());
  
  // Identificar todos os IDs de usuários através dos campos hidden (member_ID)
  const userIdsInForm = entries
    .filter(([key]) => key.startsWith('member_'))
    .map(([key]) => key.replace('member_', ''));

  for (const uid of userIdsInForm) {
    const isPresent = formData.get(`presence_${uid}`) === 'on';
    const obs = formData.get(`observation_${uid}`)?.toString() || null;
    presencePromises.push(prisma.presence.create({ 
      data: { 
        meetingId: finalMeetingId, 
        userId: uid, 
        isPresent, 
        observations: obs 
      } 
    }));
  }
  await Promise.all(presencePromises);

  return Astro.redirect(`/presenca?saved=1`);
}
---

<AppLayout title={meeting ? "Editar Presença" : "Nova Presença"}>
  <div class="space-y-6 max-w-3xl mx-auto">
    <header class="flex items-center gap-4">
      <a href="/presenca" class="w-10 h-10 rounded-lg bg-white shadow flex items-center justify-center hover:bg-gray-50 transition-colors">
        <ChevronLeft size={18} />
      </a>
      <div>
        <h1 class="text-xl font-bold">{meeting ? "Editar Presença" : "Registrar Nova Presença"}</h1>
        <p class="text-sm text-gray-500">Registre os detalhes e a lista de presença da célula.</p>
      </div>
    </header>

    <form method="GET" class="flex gap-2 items-center" id="filter-form">
      {meeting && <input type="hidden" name="meetingId" value={meeting.id} />}
      <select name="cellId" class="px-4 py-2.5 rounded-2xl border bg-white text-sm focus:ring-2 focus:ring-brand-primary/20 outline-none transition-all" onchange="document.getElementById('filter-form').submit()">
        <option value="">Selecione a célula</option>
        {availableCells.map(c => (
          <option value={c.id} selected={selectedCellId === c.id}>{c.name}</option>
        ))}
      </select>
      <input type="date" name="date" value={selectedDate.toISOString().slice(0,10)} class="px-4 py-2.5 rounded-2xl border bg-white text-sm focus:ring-2 focus:ring-brand-primary/20 outline-none transition-all" onchange="document.getElementById('filter-form').submit()" />
    </form>

    {selectedCellId ? (
      <form id="presenca-form" method="POST" enctype="multipart/form-data" class="space-y-4">
        {url.searchParams.get('existing') && (
          <div class="bg-amber-50 border border-amber-100 text-amber-800 p-4 rounded-2xl text-sm">
            <strong>Aviso:</strong> Já existe um encontro registrado para esta célula nesta data. Você está agora no modo de edição deste encontro.
          </div>
        )}

        {meeting && (
          <div class="bg-white p-4 rounded-2xl shadow-sm border border-gray-100">
            <div class="flex items-center justify-between">
              <div>
                <div class="text-sm text-gray-500">Encontro em:</div>
                <div class="font-bold text-gray-800">{new Date(meeting.date).toLocaleString()}</div>
                <div class="text-xs text-gray-400 mt-1">Célula: <span class="font-medium text-gray-600">{meeting.cell?.name}</span></div>
              </div>
              {meeting.photoUrl && (
                <img src={meeting.photoUrl} alt="Foto do encontro" class="w-20 h-20 object-cover rounded-xl shadow-sm border border-gray-100" />
              )}
            </div>
          </div>
        )}
        
        {meeting && <input type="hidden" name="meetingId" value={meeting.id} />}
        <input type="hidden" name="cellId" value={selectedCellId} />
        <input type="hidden" name="date" value={selectedDate.toISOString()} />

        <div class="bg-white p-5 rounded-2xl shadow-sm border border-gray-100">
          <label class="block text-sm font-bold text-gray-700 mb-2">Tópico do Encontro (opcional)</label>
          <input name="topic" placeholder="Ex: Estudo sobre a passagem de João 3:16" class="w-full px-4 py-2.5 rounded-xl border bg-gray-50 focus:bg-white focus:ring-2 focus:ring-brand-primary/20 outline-none transition-all text-sm" value={meeting?.topic || ''} />
          
          <label class="block text-sm font-bold text-gray-700 mt-4 mb-2">Foto do Encontro (opcional)</label>
          <div class="flex flex-col sm:flex-row items-center gap-4">
            <div id="photo-preview-container" class="hidden w-24 h-24 rounded-xl overflow-hidden border border-gray-200 shrink-0 relative">
              <img id="photo-preview" src="" class="w-full h-full object-cover" />
              <div id="photo-loading" class="absolute inset-0 bg-black/50 flex flex-col items-center justify-center hidden">
                <div class="w-5 h-5 border-2 border-white border-t-transparent rounded-full animate-spin"></div>
                <span class="text-[8px] text-white font-bold mt-1 uppercase">Processando</span>
              </div>
            </div>
            <label class="flex-1 w-full cursor-pointer">
              <div class="w-full px-4 py-6 border-2 border-dashed border-gray-200 rounded-xl bg-gray-50 hover:bg-gray-100 transition-colors flex flex-col items-center justify-center gap-2 text-sm text-gray-500 font-medium">
                <Camera size={24} class="text-brand-primary/50" />
                <span id="photo-label">Clique para anexar uma foto</span>
              </div>
              <input type="file" name="photo" accept="image/*" class="hidden" id="photo-input" />
            </label>
          </div>
          
          <label class="block text-sm font-bold text-gray-700 mt-4 mb-2">Relatório Geral / Observações</label>
          <textarea name="report" rows="3" class="w-full p-3 rounded-xl border bg-gray-50 focus:bg-white focus:ring-2 focus:ring-brand-primary/20 outline-none transition-all text-sm" placeholder="Resumo de como foi o encontro, número total de visitantes (caso não queira colocar por membro), pedidos de oração, etc.">{meeting?.report || ''}</textarea>
        </div>

        <section class="bg-white p-5 rounded-2xl shadow-sm border border-gray-100">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-bold text-gray-800 text-lg">Lista de Presença</h3>
            <span class="text-xs font-bold bg-brand-light/20 text-brand-primary px-3 py-1 rounded-full">{members.length} membros</span>
          </div>
          
          <div class="space-y-3">
            {members.map(m => (
              <div class="flex flex-col sm:flex-row sm:items-center justify-between p-4 rounded-xl border border-gray-100 hover:border-brand-primary/30 transition-colors gap-3">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-full bg-brand-light/30 text-brand-dark flex items-center justify-center font-bold text-sm">
                    {m.user.name?.charAt(0)}
                  </div>
                  <div>
                    <div class="font-bold text-gray-800">{m.user.name}</div>
                    <div class="text-xs text-gray-500 font-medium">{m.user.role}</div>
                    <input type="hidden" name={`member_${m.user.id}`} value="1" />
                  </div>
                </div>
                
                <div class="flex items-center gap-4 sm:w-1/2 justify-end">
                  <input type="text" name={`observation_${m.user.id}`} placeholder="Obs. (ex: trouxe visitante)" class="w-full sm:w-auto flex-1 px-3 py-1.5 rounded-lg border bg-gray-50 text-xs focus:ring-2 focus:ring-brand-primary/20 outline-none transition-all" value={meeting ? meetingPresencesMap.get(m.user.id)?.observations || '' : ''} />
                  
                  <label class="flex items-center gap-2 cursor-pointer relative">
                    <input type="checkbox" name={`presence_${m.user.id}`} checked={meeting ? !!(meetingPresencesMap.get(m.user.id)?.isPresent) : true} class="w-6 h-6 rounded text-brand-primary border-gray-300 focus:ring-brand-primary cursor-pointer" />
                    <span class="text-sm font-bold text-gray-700 select-none">Presente</span>
                  </label>
                </div>
              </div>
            ))}
          </div>
        </section>

        <div class="flex justify-end gap-3 pt-4 pb-8">
          <a href="/presenca" class="px-6 py-3 rounded-2xl border text-gray-700 font-bold hover:bg-gray-50 transition-colors">Cancelar</a>
          <button id="presenca-submit" type="submit" class="px-6 py-3 rounded-2xl bg-brand-primary text-white font-bold hover:brightness-110 shadow-lg shadow-brand-primary/20 transition-all">Salvar Presença</button>
        </div>
      </form>
    ) : (
      <div class="bg-white p-8 rounded-2xl text-center shadow-sm border border-gray-100">
        <div class="w-16 h-16 rounded-full bg-amber-50 flex items-center justify-center mx-auto mb-4">
          <span class="text-2xl">👉</span>
        </div>
        <h3 class="font-bold text-gray-800 mb-1">Selecione uma célula</h3>
        <p class="text-sm text-gray-500">Escolha a célula e a data acima para carregar a lista de membros e registrar a presença.</p>
      </div>
    )}
  </div>

  <script type="module">
  import { compressImage } from '../../lib/image-compression';

  const postForm = document.getElementById('presenca-form');
  if (postForm) {
    postForm.addEventListener('submit', () => {
      const btn = document.getElementById('presenca-submit');
      if (btn) {
        btn.innerHTML = 'Salvando...';
        btn.style.opacity = '0.7';
        btn.style.pointerEvents = 'none';
      }
    });
  }

  const photoInput = document.getElementById('photo-input');
  const photoPreviewContainer = document.getElementById('photo-preview-container');
  const photoPreview = document.getElementById('photo-preview');
  const photoLoading = document.getElementById('photo-loading');
  const photoLabel = document.getElementById('photo-label');

  photoInput?.addEventListener('change', async (e) => {
    const target = e.target;
    if (!target.files || target.files.length === 0) return;

    const file = target.files[0];
    
    if (photoPreviewContainer && photoPreview && photoLabel) {
      photoPreviewContainer.classList.remove('hidden');
      photoLabel.innerText = "Alterar foto";
      if (photoLoading) photoLoading.classList.remove('hidden');
      
      const reader = new FileReader();
      reader.onload = (re) => {
        photoPreview.src = re.target.result;
      };
      reader.readAsDataURL(file);
    }

    if (file.type.startsWith('image/')) {
      try {
        const compressedFile = await compressImage(file);
        const dataTransfer = new DataTransfer();
        dataTransfer.items.add(compressedFile);
        target.files = dataTransfer.files;
      } catch (err) {
        console.error('Erro ao comprimir imagem:', err);
      } finally {
        if (photoLoading) photoLoading.classList.add('hidden');
      }
    } else {
      if (photoLoading) photoLoading.classList.add('hidden');
    }
  });
  </script>
</AppLayout>

