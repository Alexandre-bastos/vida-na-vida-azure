---
import ReportLayout from '../../../layouts/ReportLayout.astro';
import { getSession } from 'auth-astro/server';
import prisma from '../../../lib/prisma';
import { ChevronLeft, Megaphone, Camera } from 'lucide-react';

const session = await getSession(Astro.request);
if (!session) return Astro.redirect('/login');

const userRole = (session.user as any)?.role;
if (userRole !== 'ADMIN' && userRole !== 'COORDENADOR') {
  return Astro.redirect('/');
}

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const title = formData.get('title')?.toString();
  const content = formData.get('content')?.toString();
  const active = formData.get('active') === 'on';

  // Upload imagem via Vercel Blob
  const image = formData.get('image') as unknown as File;
  let imageUrl = null;
  
  if (image && (image as any).size > 0) {
    try {
      const { put } = await import('@vercel/blob');
      const buffer = await (image as any).arrayBuffer();
      const blob = await put(`avisos/${Date.now()}-${(image as any).name}`, buffer, {
        access: 'public',
      });
      imageUrl = blob.url;
    } catch (err) {
      console.error("Erro ao fazer upload da imagem do aviso:", err);
    }
  }

  if (title && content) {
    await prisma.notice.create({
      data: { title, content, imageUrl, active }
    });
    return Astro.redirect('/relatorios/avisos');
  }
}
---

<ReportLayout title="Novo Aviso" activeTab="geral">
  <header class="flex items-center gap-4 mb-8">
    <a href="/relatorios/avisos" class="w-10 h-10 rounded-xl bg-white shadow-sm border border-gray-100 flex items-center justify-center text-gray-500 hover:text-brand-primary transition-colors">
      <ChevronLeft size={20} />
    </a>
    <div>
      <h2 class="text-xl font-bold text-brand-dark">Criar Novo Aviso</h2>
      <p class="text-xs text-gray-500">Este aviso aparecerá no topo da tela inicial.</p>
    </div>
  </header>

  <form method="POST" enctype="multipart/form-data" class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-gray-100 space-y-6 max-w-2xl">
    <div class="space-y-1.5">
      <label class="text-[11px] font-bold text-gray-400 uppercase tracking-widest ml-1">Título do Aviso</label>
      <input 
        type="text" 
        name="title" 
        required 
        placeholder="Ex: Conferência Vida na Vida"
        class="w-full px-5 py-4 rounded-2xl border border-gray-100 bg-gray-50/50 focus:bg-white focus:outline-none focus:ring-4 focus:ring-brand-primary/5 transition-all"
      />
    </div>

    <div class="space-y-1.5">
      <label class="text-[11px] font-bold text-gray-400 uppercase tracking-widest ml-1">Conteúdo do Informativo</label>
      <textarea 
        name="content" 
        required 
        rows="4"
        placeholder="Escreva aqui os detalhes do aviso..."
        class="w-full px-5 py-4 rounded-2xl border border-gray-100 bg-gray-50/50 focus:bg-white focus:outline-none focus:ring-4 focus:ring-brand-primary/5 transition-all resize-none"
      ></textarea>
    </div>

    <div class="space-y-1.5">
      <label class="text-[11px] font-bold text-gray-400 uppercase tracking-widest ml-1">Imagem do Aviso (Opcional)</label>
      <div class="flex flex-col sm:flex-row gap-4 items-center">
        <div id="image-preview-container" class="hidden w-24 h-24 rounded-2xl overflow-hidden border border-gray-100 shrink-0 relative">
          <img id="image-preview" src="" class="w-full h-full object-cover" />
          <div id="image-loading" class="absolute inset-0 bg-black/50 flex flex-col items-center justify-center hidden">
            <div class="w-5 h-5 border-2 border-white border-t-transparent rounded-full animate-spin"></div>
            <span class="text-[8px] text-white font-bold mt-1 uppercase">Processando</span>
          </div>
        </div>
        <label class="flex-1 w-full cursor-pointer">
          <div id="drop-zone" class="w-full px-5 py-8 border-2 border-dashed border-gray-100 rounded-2xl bg-gray-50/50 hover:bg-white hover:border-brand-primary/30 transition-all flex flex-col items-center justify-center gap-2 text-sm text-gray-500 font-medium">
            <div class="w-12 h-12 bg-white rounded-xl shadow-sm flex items-center justify-center text-brand-primary">
              <Camera size={24} />
            </div>
            <span id="file-name">Clique para anexar uma foto</span>
          </div>
          <input type="file" name="image" accept="image/*" class="hidden" id="image-input" />
        </label>
      </div>
    </div>

    <script>
      import { compressImage } from '../../../lib/image-compression';
      
      const imageInput = document.getElementById('image-input') as HTMLInputElement;
      const fileNameDisplay = document.getElementById('file-name');
      const imagePreviewContainer = document.getElementById('image-preview-container');
      const imagePreview = document.getElementById('image-preview') as HTMLImageElement;
      const imageLoading = document.getElementById('image-loading');
      
      imageInput?.addEventListener('change', async (e: any) => {
        const target = e.target as HTMLInputElement;
        if (!target.files || target.files.length === 0) return;

        const file = target.files[0];
        
        if (imagePreviewContainer && imagePreview && fileNameDisplay) {
          imagePreviewContainer.classList.remove('hidden');
          fileNameDisplay.innerText = "Alterar imagem";
          if (imageLoading) imageLoading.classList.remove('hidden');
          
          const reader = new FileReader();
          reader.onload = (re: any) => {
            imagePreview.src = re.target.result;
          };
          reader.readAsDataURL(file);
        }
        
        if (file.type.startsWith('image/')) {
          try {
            const compressedFile = await compressImage(file);
            const dataTransfer = new DataTransfer();
            dataTransfer.items.add(compressedFile);
            target.files = dataTransfer.files;
          } catch (err) {
            console.error('Erro ao comprimir imagem:', err);
          } finally {
            if (imageLoading) imageLoading.classList.add('hidden');
          }
        } else {
          if (imageLoading) imageLoading.classList.add('hidden');
        }
      });

      // Submit loading state
      const form = document.querySelector('form');
      const submitBtn = document.getElementById('submit-btn');
      const submitText = document.getElementById('submit-text');
      const submitIcon = document.getElementById('submit-icon');

      if (form) {
        form.addEventListener('submit', () => {
          if (submitBtn && submitText) {
            submitBtn.style.pointerEvents = 'none';
            submitBtn.style.opacity = '0.7';
            submitText.innerText = 'Processando...';
            if (submitIcon) {
              submitIcon.innerHTML = '<div class="w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin"></div>';
            }
          }
        });
      }
    </script>

    <div class="flex items-center gap-3 p-4 bg-gray-50 rounded-2xl">
      <label class="relative inline-flex items-center cursor-pointer">
        <input type="checkbox" name="active" checked class="sr-only peer">
        <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-brand-primary/20 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-brand-primary"></div>
      </label>
      <span class="text-sm font-bold text-gray-600">Ativar este aviso imediatamente</span>
    </div>

    <div class="flex gap-4 pt-4">
      <a href="/relatorios/avisos" class="flex-1 px-6 py-4 rounded-2xl border border-gray-100 font-bold text-gray-400 text-center hover:bg-gray-50 transition-all">Cancelar</a>
      <button id="submit-btn" type="submit" class="flex-1 px-6 py-4 rounded-2xl bg-brand-primary text-white font-bold hover:brightness-110 shadow-lg shadow-brand-primary/20 transition-all flex items-center justify-center gap-2">
        <span id="submit-icon"><Megaphone size={18} /></span>
        <span id="submit-text">Publicar Aviso</span>
      </button>
    </div>
  </form>
</ReportLayout>

