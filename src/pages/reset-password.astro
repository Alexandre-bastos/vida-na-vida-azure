---
import AppLayout from '../layouts/AppLayout.astro';
import { Lock, CheckCircle2, AlertCircle } from 'lucide-react';

const { searchParams } = Astro.url;
const token = searchParams.get('token');

// Se não houver token, redireciona para o login
if (!token) return Astro.redirect('/login');

const user = Astro.locals.user;
if (user) return Astro.redirect('/');
---

<AppLayout title="Redefinir Senha">
  <div class="min-h-[80vh] flex flex-col items-center justify-center px-4">
    <div class="w-full max-w-md bg-white p-8 rounded-[2.5rem] shadow-sm border border-gray-100">
      <div class="text-center mb-8">
        <div class="w-16 h-16 bg-blue-50 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <Lock size={32} class="text-blue-500" />
        </div>
        <h1 class="text-2xl font-bold text-gray-900">Nova Senha</h1>
        <p class="text-gray-500 mt-2">Crie uma senha forte e segura para sua conta.</p>
      </div>

      <form id="reset-password-form" class="space-y-6">
        <input type="hidden" name="token" value={token} />
        
        <div>
          <label for="password" class="block text-sm font-semibold text-gray-700 mb-2">Nova Senha</label>
          <div class="relative">
            <Lock class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400" size={20} />
            <input 
              type="password" 
              id="password" 
              name="password" 
              required 
              minlength="6"
              placeholder="••••••••"
              class="w-full pl-12 pr-4 py-4 bg-gray-50 border-none rounded-2xl focus:ring-2 focus:ring-blue-500 transition-all outline-none"
            />
          </div>
        </div>

        <div>
          <label for="confirmPassword" class="block text-sm font-semibold text-gray-700 mb-2">Confirmar Nova Senha</label>
          <div class="relative">
            <Lock class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400" size={20} />
            <input 
              type="password" 
              id="confirmPassword" 
              name="confirmPassword" 
              required 
              minlength="6"
              placeholder="••••••••"
              class="w-full pl-12 pr-4 py-4 bg-gray-50 border-none rounded-2xl focus:ring-2 focus:ring-blue-500 transition-all outline-none"
            />
          </div>
        </div>

        <button 
          type="submit" 
          class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 rounded-2xl shadow-lg shadow-blue-200 transition-all flex items-center justify-center gap-2 group"
        >
          <span>Redefinir Senha</span>
          <CheckCircle2 size={18} class="group-hover:scale-110 transition-transform" />
        </button>

        <div id="message-area" class="hidden p-4 rounded-2xl text-sm font-medium flex items-center gap-2"></div>
      </form>

      <div id="success-screen" class="hidden text-center space-y-6 py-4">
        <div class="w-16 h-16 bg-green-50 rounded-full flex items-center justify-center mx-auto">
          <CheckCircle2 size={32} class="text-green-500" />
        </div>
        <h2 class="text-xl font-bold text-gray-900">Senha Alterada!</h2>
        <p class="text-gray-500">Sua nova senha foi salva com sucesso. Você já pode fazer login.</p>
        <a href="/login" class="block w-full bg-gray-900 text-white font-bold py-4 rounded-2xl hover:bg-black transition-colors">
          Ir para o Login
        </a>
      </div>
    </div>
  </div>
</AppLayout>

<script>
  const form = document.getElementById('reset-password-form') as HTMLFormElement;
  const messageArea = document.getElementById('message-area');
  const successScreen = document.getElementById('success-screen');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const password = formData.get('password');
    const confirmPassword = formData.get('confirmPassword');
    const token = formData.get('token');

    if (password !== confirmPassword) {
      if (messageArea) {
        messageArea.classList.remove('hidden', 'bg-green-50', 'text-green-700');
        messageArea.classList.add('bg-red-50', 'text-red-700');
        messageArea.innerText = 'As senhas não coincidem';
      }
      return;
    }

    try {
      const response = await fetch('/api/auth/reset-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token, password })
      });

      const result = await response.json();

      if (response.ok) {
        form.classList.add('hidden');
        successScreen?.classList.remove('hidden');
      } else {
        if (messageArea) {
          messageArea.classList.remove('hidden', 'bg-green-50', 'text-green-700');
          messageArea.classList.add('bg-red-50', 'text-red-700');
          messageArea.innerText = result.error || 'Erro ao redefinir senha';
        }
      }
    } catch (error) {
       if (messageArea) {
        messageArea.classList.remove('hidden');
        messageArea.classList.add('bg-red-50', 'text-red-700');
        messageArea.innerText = 'Erro de conexão. Tente novamente.';
      }
    }
  });
</script>
